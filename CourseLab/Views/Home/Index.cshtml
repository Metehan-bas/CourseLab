@{
    Layout = null;
}
@using Microsoft.AspNetCore.Http
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CourseLab</title>
    <link rel="stylesheet" href="/css/home.css" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-20 items-center justify-between">
                <div class="flex items-center">
                    <a href="/">
                        <img src="/img/Course_Lab-removebg-preview.png"
                             class="h-20 w-20" />
                    </a>

                    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-gray-700 dark:text-gray-200">
                        <a href="/Courses/Index" class="hover:text-indigo-600">Courses</a>
                        <a href="/html/contact.html" class="hover:text-indigo-600">Contact</a>

                        @if (Context.Session.GetString("Role") != "Instructor")
                        {   
                            <a href="/Instructor/Apply"
                               class="ml-2 bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">
                                Become an Instructor
                            </a>
                        }
                        @if (Context.Session.GetString("Role") == "Instructor")
                        {
                            <a href=""
                               class="ml-2 bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">
                                Add Course
                            </a>
                        }
                    </nav>
                </div>
                <div id="rightSide" class="flex items-center gap-3 relative">

                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <div class="relative">

                            <div onclick="toggleMenu()"
                                 class="flex items-center gap-x-2 cursor-pointer">

                                <img class="object-cover w-10 h-10 rounded-full"
                                     src="~/img/PNg.png"
                                     alt="">

                                <div>
                                    <h1 class="text-lg font-semibold text-gray-700 dark:text-white">
                                        @Context.Session.GetString("UserName")
                                    </h1>

                                    <p class="text-sm text-gray-500 dark:text-gray-400">
                                        @Context.Session.GetString("Email")
                                    </p>
                                </div>
                            </div>

                            <div id="dropdownMenu"
                                 class="hidden absolute right-0 mt-3 w-40 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden z-50">

                                <a href="/Account/Profile"
                                   class="block px-4 py-2 text-sm text-gray-700 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700">
                                    Profile
                                </a>

                                <a href="/Account/Logout"
                                   class="block px-4 py-2 text-sm text-red-600 hover:bg-gray-100 dark:hover:bg-gray-700">
                                    Logout
                                </a>

                            </div>

                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login"
                           class="text-sm font-semibold text-gray-700 dark:text-white hover:text-indigo-600">
                            Login
                        </a>

                        <a href="/Student/Register"
                           class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-black dark:bg-white dark:text-black hover:text-white">
                            Register
                        </a>
                    }

                </div>


            </div>
        </div>

        <div id="mobileMenu"
             class="hidden md:hidden bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
            <div class="px-4 py-4 flex flex-col gap-4 text-sm font-semibold text-gray-700 dark:text-white">
                <a href="/Courses/courses" class="hover:text-indigo-600">Courses</a>
                <a href="/html/contact.html" class="hover:text-indigo-600">Contact</a>

                @if (Context.Session.GetString("Role") != "Instructor")
                {
                    <a href="/Instructor/Apply"
                       class="ml-2 bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700">
                        Become an Instructor
                    </a>
                }
            </div>
        </div>
    </header>

    <div class="relative isolate overflow-hidden bg-white min-h-screen flex items-center justify-center dark:bg-gray-900">
        <img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=2830&q=80"
             class="absolute inset-0 -z-10 w-full h-full object-cover opacity-40" />

        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div id="yazi1" class="mx-auto max-w-2xl lg:mx-0">
                <h2 class="text-5xl font-semibold tracking-tight text-gray-900 sm:text-7xl dark:text-white">
                    Become an instructor
                </h2>

                <p class="mt-8 text-lg font-medium text-pretty text-gray-700 sm:text-xl/8 dark:text-gray-300">
                    Share your knowledge and reach thousands of students worldwide.
                </p>
            </div>

            <div id="yazi2" class="mx-auto mt-10 max-w-2xl lg:mx-0 lg:max-w-none">
                <dl class="mt-16 grid grid-cols-1 gap-8 sm:mt-20 sm:grid-cols-2 lg:grid-cols-4">
                    <div class="flex flex-col-reverse gap-1">
                        <dt class="text-base/7 text-gray-700 dark:text-gray-300">
                            Students worldwide
                        </dt>
                        <dd class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white">
                            10,000+
                        </dd>
                    </div>

                    <div class="flex flex-col-reverse gap-1">
                        <dt class="text-base/7 text-gray-700 dark:text-gray-300">
                            Active instructors
                        </dt>
                        <dd class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white">
                            500+
                        </dd>
                    </div>

                    <div class="flex flex-col-reverse gap-1">
                        <dt class="text-base/7 text-gray-700 dark:text-gray-300">
                            Courses published
                        </dt>
                        <dd class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white">
                            1,200+
                        </dd>
                    </div>

                    <div class="flex flex-col-reverse gap-1">
                        <dt class="text-base/7 text-gray-700 dark:text-gray-300">
                            Earning potential
                        </dt>
                        <dd class="text-4xl font-semibold tracking-tight text-gray-900 dark:text-white">
                            Unlimited
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    <footer class="bg-gray-950 text-gray-300">
        <div class="max-w-7xl mx-auto px-6 py-14">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                <div>
                    <h2 class="text-2xl font-bold text-white">CourseLab</h2>
                    <p class="mt-4 text-sm text-gray-400">
                        Online learning platform. Grow your skills with expert
                        instructors.
                    </p>
                </div>

                <div>
                    <h3 class="text-white font-semibold mb-4">Company</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/html/contact.html" class="hover:text-white">Contact</a></li>
                        <li>
                            <a href="/Instructor/Apply" class="hover:text-white">Become an Instructor</a>
                        </li>
                        <li><a href="#" class="hover:text-white">FAQ</a></li>
                    </ul>
                </div>

                <div>
                    <h3 class="text-white font-semibold mb-4">Newsletter</h3>

                    <div class="flex">
                        <input type="email"
                               placeholder="Email"
                               class="w-full px-3 py-2 rounded-l-lg bg-gray-800 border border-gray-700 text-sm focus:outline-none" />
                        <button class="bg-indigo-600 px-4 rounded-r-lg text-sm">
                            Subscribe
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script>
        const btn = document.getElementById("menuBtn");
        const menu = document.getElementById("mobileMenu");
        btn.onclick = () => menu.classList.toggle("hidden");
    </script>
    <script>
        const userName = '@Context.Session.GetString("UserName")';
    </script>
    <script src="/js/script.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const btn = document.getElementById("userBtn");
            const menu = document.getElementById("dropdownMenu");

            if (!btn || !menu) return;

            btn.addEventListener("click", function (e) {
                e.stopPropagation();
                menu.classList.toggle("hidden");
            });

            document.addEventListener("click", function () {
                menu.classList.add("hidden");
            });

        });
    </script>

    <script id="e9d0vz">
        function toggleMenu() {
            document
                .getElementById("dropdownMenu")
                .classList.toggle("hidden");
        }
    </script>
</body>
</html>
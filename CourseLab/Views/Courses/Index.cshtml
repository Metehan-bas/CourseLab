                        Limits
                    </h1>

                    <h1 class="text-white text-5xl lg:text-7xl font-extrabold leading-tight mt-2">
                        Build Your Future
                    </h1>

                    <p class="text-gray-300 text-lg lg:text-xl mt-8 leading-9 max-w-2xl">
                        Start learning from expert instructors and build
                        real-world skills with modern online courses.
                    </p>

                    <div class="flex gap-5 mt-10">

                        <button class="px-8 py-4 bg-blue-500 text-white rounded-2xl text-lg font-semibold hover:bg-blue-600 duration-300 shadow-2xl">
                            Explore Courses
                        </button>

                        <button class="px-8 py-4 border border-white text-white rounded-2xl text-lg font-semibold hover:bg-white hover:text-black duration-300">
                            Learn More
                        </button>

                    </div>

                    <div class="flex gap-12 mt-14">

                        <div>
                            <h2 class="text-4xl font-bold text-white">
                                10K+
                            </h2>

                            <p class="text-gray-400 mt-2">
                                Students
                            </p>
                        </div>

                        <div>
                            <h2 class="text-4xl font-bold text-white">
                                500+
                            </h2>

                            <p class="text-gray-400 mt-2">
                                Courses
                            </p>
                        </div>

                        <div>
                            <h2 class="text-4xl font-bold text-white">
                                120+
                            </h2>

                            <p class="text-gray-400 mt-2">
                                Instructors
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>


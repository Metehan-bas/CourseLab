@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CourseLab</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: Poppins,sans-serif;
            margin: 0;
            padding: 0;
            background: #0B1120;
        }

        html {
            scroll-behavior: smooth;
        }
    </style>
</head>

<body>

    <header id="navbar"
            class="fixed top-0 left-0 w-full z-50 bg-transparent border-b border-white/10 backdrop-blur-md transition duration-300">

        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

            <div class="flex h-20 items-center justify-between">

                <div class="flex items-center gap-10">

                    <a href="/">
                        <img src="/img/Course_Lab-removebg-preview.png"
                             class="h-20 w-20 object-contain" />
                    </a>

                    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-white">

                        <a href="/Courses/Index"
                           class="hover:text-blue-400 duration-300">
                            Courses
                        </a>

                        <a href="/html/contact.html"
                           class="hover:text-blue-400 duration-300">
                            Contact
                        </a>

                        @if (Context.Session.GetString("Role") != "Instructor")
                        {
                            <a href="/Instructor/Apply"
                               class="bg-blue-500 text-white px-5 py-3 rounded-xl hover:bg-blue-600 duration-300 shadow-lg">
                                Become Instructor
                            </a>
                        }

                        @if (Context.Session.GetString("Role") == "Instructor")
                        {
                            <a href=""
                               class="bg-blue-500 text-white px-5 py-3 rounded-xl hover:bg-blue-600 duration-300 shadow-lg">
                                Add Course
                            </a>
                        }

                    </nav>

                </div>

                <div id="rightSide" class="flex items-center gap-3 relative">

                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <div class="relative">

                            <div onclick="toggleMenu()"
                                 class="flex items-center gap-x-3 cursor-pointer">

                                <img class="object-cover w-12 h-12 rounded-full border-2 border-blue-500"
                                     src="~/img/PNg.png">

                                <div>
                                    <h1 class="text-lg font-semibold text-white">
                                        @Context.Session.GetString("UserName")
                                    </h1>

                                    <p class="text-sm text-gray-300">
                                        @Context.Session.GetString("Role")
                                    </p>
                                </div>

                            </div>

                            <div id="dropdownMenu"
                                 class="hidden absolute right-0 mt-4 w-48 bg-[#111827] rounded-2xl shadow-2xl border border-gray-700 overflow-hidden">

                                <a href="/Account/Profile"
                                   class="block px-5 py-3 text-sm text-white hover:bg-gray-700 duration-300">
                                    Profile
                                </a>

                                <a href="/Account/Logout"
                                   class="block px-5 py-3 text-sm text-red-400 hover:bg-gray-700 duration-300">
                                    Logout
                                </a>

                            </div>

                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login"
                           class="text-sm font-semibold text-white hover:text-blue-400 duration-300">
                            Login
                        </a>

                        <a href="/Student/Register"
                           class="bg-white text-black px-5 py-3 rounded-xl text-sm font-semibold hover:bg-gray-200 duration-300">
                            Register
                        </a>
                    }

                </div>

            </div>

        </div>

    </header>

    <section>

        <div class="w-full h-[42rem] bg-cover bg-center bg-no-repeat relative"
             style="background-image:url('../img/a.png')">

            <div class="absolute inset-0 bg-gradient-to-r from-[#0B1120]/95 via-[#0B1120]/70 to-transparent flex items-center">

                <div class="pl-10 lg:pl-24 max-w-3xl">

                    <span class="bg-blue-500 text-white px-5 py-2 rounded-full text-sm font-semibold shadow-lg">
                        #1 Online Learning Platform
                    </span>

                    <h1 class="text-white text-5xl lg:text-7xl font-extrabold leading-tight mt-8">
                        Learn Without
                    </h1>

